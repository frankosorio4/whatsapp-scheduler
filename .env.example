# Google Sheets
SPREADSHEET_ID=your_google_spreadsheet_id_here

# WhatsApp - Owner number (include country code, no + or spaces)
OWNER_NUMBER=5511999999999

# Google Service Account credentials (required on server - not needed locally if creds.json is present)
# To generate: paste the entire contents of creds.json as a single line
# Example: GOOGLE_CREDS_JSON={"type":"service_account","project_id":"..."}
GOOGLE_CREDS_JSON=

# Chrome executable path for Puppeteer
# Locally: leave empty - Puppeteer uses its own bundled browser
# On the server: set to /usr/bin/chromium-browser
CHROME_PATH=
